rules_version = '2';
// ─────────────────────────────────────────────────────────────
//  CONTAPP AUDITOR — Reglas Firestore v2
//  Cambios respecto a v1:
//    - perfiles: lectura restringida (solo propio + titular del invitado)
//    - perfiles: escritura de otro uid limitada a campos de canje de invitación
//    - invitaciones: list bloqueado; create solo a usuarios no-anónimos
//      con titularUid == propio; update separado por titular vs invitado
//    - empresas/create: bloqueado para sesiones anónimas
// ─────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function esMiembro(empresaId) {
      return exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid));
    }
    function rolEn(empresaId) {
      return get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.rol;
    }
    function esAdmin(empresaId) {
      return rolEn(empresaId) == 'admin';
    }
    function puedeEscribir(empresaId) {
      return rolEn(empresaId) in ['admin', 'contador', 'asistente'];
    }
    function esAnonimo() {
      return request.auth.token.email == null;
    }

    // ── Perfiles ─────────────────────────────────────────────
    match /perfiles/{uid} {

      // Lectura de un perfil específico:
      //   - Siempre puede leer el propio
      //   - Invitado puede leer el perfil del titular si su uid está en invitados[]
      //     (necesario para que _fbCargarPerfil cargue las empresas del titular)
      allow get:  if request.auth != null && (
        request.auth.uid == uid ||
        request.auth.uid in resource.data.invitados
      );

      // Nadie puede listar todos los perfiles
      allow list: if false;

      // El usuario solo puede escribir su propio perfil
      allow write: if request.auth != null && request.auth.uid == uid;

      // Canje de invitación: cuando un invitado acepta, escribe en el perfil
      // del TITULAR para mover el código y agregar su uid.
      // Solo se permiten cambios en codigosActivos e invitados; no se puede
      // quitar elementos de invitados ni agregar campos nuevos.
      allow update: if request.auth != null &&
        request.auth.uid != uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['codigosActivos', 'invitados']) &&
        request.resource.data.invitados.hasAll(resource.data.invitados) &&
        resource.data.codigosActivos.hasAll(request.resource.data.codigosActivos);
    }

    // ── Invitaciones ─────────────────────────────────────────
    match /invitaciones/{codigo} {

      // Cualquier usuario autenticado (incluye anónimos) puede leer
      // una invitación específica por su código — el código es el secreto.
      allow get:  if request.auth != null;

      // Nadie puede enumerar todas las invitaciones
      allow list: if false;

      // Solo usuarios registrados (no anónimos) pueden crear invitaciones,
      // y únicamente con su propio uid como titularUid.
      allow create: if request.auth != null &&
        !esAnonimo() &&
        request.resource.data.titularUid == request.auth.uid;

      // Titular puede revocar o modificar su propia invitación.
      // Invitado puede únicamente marcar como usada (campos fijos).
      allow update: if request.auth != null && (
        resource.data.titularUid == request.auth.uid ||
        (resource.data.usada == false &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['usada', 'usadaPor', 'usadaEn']))
      );

      // Solo el titular puede eliminar sus invitaciones
      allow delete: if request.auth != null &&
        resource.data.titularUid == request.auth.uid;
    }

    // ── Empresas y subcolecciones ─────────────────────────────
    match /empresas/{empresaId} {

      // Las sesiones anónimas (acceso por código) no pueden crear empresas
      allow create: if request.auth != null && !esAnonimo();

      // Solo miembros registrados pueden leer datos de la empresa
      allow read:   if request.auth != null && esMiembro(empresaId);

      // Solo miembros con rol distinto de 'lectura' pueden escribir
      allow update: if request.auth != null &&
        esMiembro(empresaId) && puedeEscribir(empresaId);

      // Solo el admin puede eliminar la empresa
      allow delete: if request.auth != null && esAdmin(empresaId);

      // ── Usuarios de la empresa ──────────────────────────
      match /usuarios/{uid} {

        // Cualquier usuario puede registrarse en la empresa (crear su propio doc)
        allow create: if request.auth != null && request.auth.uid == uid;

        // Cada usuario lee su propio doc; cualquier miembro ve la lista del equipo
        allow read:   if request.auth != null && (
          request.auth.uid == uid || esMiembro(empresaId)
        );

        // Solo admin puede cambiar roles o eliminar usuarios
        allow update, delete: if request.auth != null && esAdmin(empresaId);
      }

      // ── Log de auditoría ────────────────────────────────
      match /audit_log/{logId} {
        allow read:   if request.auth != null && esAdmin(empresaId);
        allow create: if request.auth != null && esMiembro(empresaId);
      }
    }
  }
}
