rules_version = '2';
// ─────────────────────────────────────────────────────────────
//  CONTAPP PUBLIC — Reglas Firestore
//  Ámbito: Organismos públicos (municipios, servicios del Estado)
//  Características:
//    - Sin acceso anónimo (funcionarios con cuenta institucional)
//    - Sin acceso público de lectura (los datos no son de transparencia activa)
//    - RBAC estricto acorde a Ley N°18.575 (LOCBGAE)
//    - Roles: admin | contador | asistente | lectura
//    - Auditoría accesible por admin y contador
//      (requerido para control de Contraloría)
//    - Sin módulo de segunda categoría
// ─────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function esMiembro(empresaId) {
      return exists(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid));
    }
    function rolEn(empresaId) {
      return get(/databases/$(database)/documents/empresas/$(empresaId)/usuarios/$(request.auth.uid)).data.rol;
    }
    function esAdmin(empresaId) {
      return rolEn(empresaId) == 'admin';
    }
    function esAdminOContador(empresaId) {
      return rolEn(empresaId) in ['admin', 'contador'];
    }
    function puedeEscribir(empresaId) {
      return rolEn(empresaId) in ['admin', 'contador', 'asistente'];
    }
    function noEsAnonimo() {
      return !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // ── Perfiles ─────────────────────────────────────────────
    // Los funcionarios gestionan solo su propio perfil
    match /perfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid && noEsAnonimo();
    }

    // ── Invitaciones ─────────────────────────────────────────
    // Solo funcionarios con cuenta propia (no anónimos)
    match /invitaciones/{codigo} {
      allow read:  if request.auth != null && noEsAnonimo();
      allow write: if request.auth != null && noEsAnonimo();
    }

    // ── Organismo y subcolecciones ───────────────────────────
    // El "organismo público" es la unidad equivalente a "empresa"
    match /empresas/{empresaId} {

      // Solo funcionarios con cuenta institucional pueden crear organismos
      allow create: if request.auth != null && noEsAnonimo();

      // Lectura: solo funcionarios miembros del organismo
      allow read: if request.auth != null && esMiembro(empresaId);

      // Escritura: miembros con rol operativo (no lectura)
      allow update: if request.auth != null && esMiembro(empresaId) && puedeEscribir(empresaId);

      // Eliminación: solo administrador del sistema (jefe de finanzas)
      allow delete: if request.auth != null && esAdmin(empresaId);

      // ── Funcionarios del organismo ───────────────────────
      match /usuarios/{uid} {
        // Auto-registro al incorporarse al organismo
        allow create: if request.auth != null && request.auth.uid == uid && noEsAnonimo();

        // Cada funcionario lee su propio registro
        allow read: if request.auth != null && request.auth.uid == uid;

        // Cualquier miembro puede ver el directorio de funcionarios
        allow read: if request.auth != null && esMiembro(empresaId);

        // Solo admin gestiona roles y accesos
        allow update, delete: if request.auth != null && esAdmin(empresaId);
      }

      // ── Log de auditoría ────────────────────────────────
      // Admin y contador pueden leer el log (requerido para Contraloría)
      // Cualquier miembro registra sus acciones
      match /audit_log/{logId} {
        allow read:   if request.auth != null && esAdminOContador(empresaId);
        allow create: if request.auth != null && esMiembro(empresaId);
      }
    }
  }
}
